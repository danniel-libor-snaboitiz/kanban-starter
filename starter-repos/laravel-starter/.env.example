APP_NAME=LaravelStarter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# The absolute path is populated by artisan when you run migrations; leaving it blank
# lets Laravel fall back to database_path('database.sqlite').
DB_DATABASE=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
